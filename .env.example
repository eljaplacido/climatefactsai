# =============================================================================
# CLILENS.AI ENVIRONMENT VARIABLES - TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=climatenews
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here

# Database URL (alternative to individual settings)
DATABASE_URL=postgresql://postgres:your-secure-password-here@localhost:5433/climatenews

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# CELERY & TASK QUEUE CONFIGURATION
# -----------------------------------------------------------------------------
# Celery broker and result backend
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json,pickle
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=True

# Celery worker settings
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_PREFETCH_MULTIPLIER=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_ACKS_LATE=True
CELERY_TASK_REJECT_ON_WORKER_LOST=True

# Task execution settings
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_TASK_DEFAULT_RATE_LIMIT=100/m

# Task queue names
CELERY_QUEUE_INGESTION=ingestion_queue
CELERY_QUEUE_PROCESSING=processing_queue
CELERY_QUEUE_VIDEO=video_queue
CELERY_QUEUE_PUBLICATION=publication_queue

# -----------------------------------------------------------------------------
# LANGGRAPH CONFIGURATION
# -----------------------------------------------------------------------------
# LangGraph checkpoint storage
LANGGRAPH_CHECKPOINT_BACKEND=postgres
LANGGRAPH_CHECKPOINT_TABLE=langgraph_checkpoints
LANGGRAPH_CHECKPOINT_NAMESPACE=climatenews

# HITL (Human-in-the-Loop) settings
LANGGRAPH_HITL_ENABLED=True
LANGGRAPH_HITL_TRUST_THRESHOLD=0.7
LANGGRAPH_HITL_KEYWORDS=nuclear,war,politics,controversial

# LangGraph state management
LANGGRAPH_STATE_TTL_HOURS=72
LANGGRAPH_MAX_ITERATIONS=10
LANGGRAPH_RECURSION_LIMIT=25

# -----------------------------------------------------------------------------
# REMOTION VIDEO RENDERING
# -----------------------------------------------------------------------------
# Remotion Lambda configuration
REMOTION_LAMBDA_ENABLED=True
REMOTION_LAMBDA_REGION=us-east-1
REMOTION_LAMBDA_FUNCTION_NAME=climatenews-video-renderer
REMOTION_LAMBDA_TIMEOUT=900
REMOTION_LAMBDA_MEMORY=3008

# Remotion rendering settings
REMOTION_COMPOSITION_NAME=ClimateNewsVideo
REMOTION_FRAME_RATE=30
REMOTION_VIDEO_WIDTH=1920
REMOTION_VIDEO_HEIGHT=1080
REMOTION_VIDEO_CODEC=h264
REMOTION_VIDEO_BITRATE=5M

# Remotion asset storage (S3)
REMOTION_ASSETS_BUCKET=climatenews-video-assets
REMOTION_OUTPUT_BUCKET=climatenews-video-outputs
REMOTION_S3_REGION=us-east-1
REMOTION_TEMPLATES_DIR=src/video_templates

# -----------------------------------------------------------------------------
# TEXT-TO-SPEECH (TTS) CONFIGURATION
# -----------------------------------------------------------------------------
# Primary TTS provider
TTS_PROVIDER=elevenlabs

# ElevenLabs TTS API (extended from EXTERNAL SERVICES)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# AWS Polly (fallback)
AWS_POLLY_VOICE_ID=Joanna

# Google TTS (fallback)
GOOGLE_TTS_VOICE_NAME=en-US-Neural2-F

# -----------------------------------------------------------------------------
# MEDIA ASSET APIS (EXTENDED)
# -----------------------------------------------------------------------------
# Pexels (extended from EXTERNAL SERVICES)
PEXELS_VIDEOS_PER_PAGE=15
PEXELS_DEFAULT_ORIENTATION=landscape
PEXELS_SIZE=large

# Asset caching
MEDIA_CACHE_DIR=/tmp/climatenews/media_cache
MEDIA_CACHE_TTL_HOURS=24

# -----------------------------------------------------------------------------
# COMPLIANCE & TRUST CONFIGURATION
# -----------------------------------------------------------------------------
# Robots.txt/noai compliance
COMPLIANCE_CHECK_ROBOTS_TXT=True
COMPLIANCE_CHECK_NOAI=True
COMPLIANCE_RESPECT_TDM_OPT_OUT=True
COMPLIANCE_LOG_SKIPS=True
COMPLIANCE_ALLOW_LIST=bbc.com,reuters.com,apnews.com
COMPLIANCE_DENY_LIST=

# Trust scoring
TRUST_SCORE_MIN=0
TRUST_SCORE_MAX=100
TRUST_SCORE_DEFAULT=50
TRUST_SCORE_THRESHOLD_LOW=40
TRUST_SCORE_THRESHOLD_HIGH=80

# Nutrition label settings
NUTRITION_LABEL_ENABLED=True
NUTRITION_LABEL_SHOW_SOURCES=True
NUTRITION_LABEL_SHOW_VERIFICATION=True

# -----------------------------------------------------------------------------
# CIRCUIT BREAKERS & RATE LIMITS
# -----------------------------------------------------------------------------
# External API rate limits (per minute)
RATE_LIMIT_LLM_CALLS=60
RATE_LIMIT_TTS_CALLS=30
RATE_LIMIT_PEXELS_CALLS=50
RATE_LIMIT_ELEVENLABS_CALLS=30

# Circuit breaker settings
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
CIRCUIT_BREAKER_HALF_OPEN_TIMEOUT=30

# Task retry configuration
TASK_RETRY_MAX_ATTEMPTS=3
TASK_RETRY_BACKOFF_BASE=2
TASK_RETRY_BACKOFF_MAX=300

# -----------------------------------------------------------------------------
# KAFKA CONFIGURATION (DEPRECATED - Phase 6 removal)
# -----------------------------------------------------------------------------
# These will be removed after migration completion
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# -----------------------------------------------------------------------------
# LLM API KEYS
# -----------------------------------------------------------------------------

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenAI API
OPENAI_API_KEY=sk-your-openai-key-here

# Perplexity AI API
PERPLEXITY_API_KEY=pplx-your-perplexity-key-here

# Dev/testing: enable mock claim extraction/evidence when API keys are missing
USE_MOCK_VERIFICATION=false

# -----------------------------------------------------------------------------
# CLIMATE DATA APIs (Optional)
# -----------------------------------------------------------------------------
CLIMATE_CHECK_API_KEY=your-climate-check-key-here
NOAA_API_KEY=your-noaa-key-here
NASA_API_KEY=your-nasa-key-here

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# STRIPE PAYMENT INTEGRATION
# -----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Webhook secret for event verification
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Product/Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_ID_BASIC=price_1234567890abcdef
STRIPE_PRICE_ID_PROFESSIONAL=price_0987654321fedcba
STRIPE_PRICE_ID_ENTERPRISE=price_enterpriseid12345

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (SendGrid)
# -----------------------------------------------------------------------------
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
FROM_EMAIL=noreply@clilens.ai
SUPPORT_EMAIL=support@clilens.ai

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
LOG_FORMAT=json

# Frontend URL (for email links, redirects)
FRONTEND_URL=http://localhost:5300

# Frontend build-time API base (Next.js)
# NOTE: port is 5400 (FastAPI default in docker-compose). The 5200 value in
# older builds was stale — runtime bundle uses 5400; keep this aligned.
NEXT_PUBLIC_API_URL=http://localhost:5400

# Frontend OAuth client IDs (public — these are not secrets, they identify the
# OAuth application to the provider; the matching CLIENT_SECRET stays on the
# backend). When empty the login page disables the corresponding button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5300

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
# Tier limits (articles per day)
RATE_LIMIT_FREEMIUM_ARTICLES=5
RATE_LIMIT_BASIC_ARTICLES=50
RATE_LIMIT_PROFESSIONAL_ARTICLES=-1
RATE_LIMIT_ENTERPRISE_ARTICLES=-1

# URL Analysis limits (per month)
RATE_LIMIT_BASIC_URL_ANALYSES=5
RATE_LIMIT_PROFESSIONAL_URL_ANALYSES=20
RATE_LIMIT_ENTERPRISE_URL_ANALYSES=-1

# API Call limits (per day)
RATE_LIMIT_PROFESSIONAL_API_CALLS=1000
RATE_LIMIT_ENTERPRISE_API_CALLS=-1

# -----------------------------------------------------------------------------
# MONITORING & OBSERVABILITY
# -----------------------------------------------------------------------------
# OpenTelemetry (traces exported via OTLP to Jaeger/Tempo/etc)
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=clilens

# Grafana
GRAFANA_ADMIN_PASSWORD=admin

# Prometheus
PROMETHEUS_SCRAPE_INTERVAL=15s

# Jaeger
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Secret key for session management
SECRET_KEY=your-app-secret-key-change-in-production

# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_NUMBERS=True
PASSWORD_REQUIRE_SPECIAL=False

# Account lockout settings
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
ENABLE_VIDEO_PRODUCTION=False
ENABLE_SEMANTIC_SEARCH=True
ENABLE_API_KEYS=True
ENABLE_EXPORT=True

# -----------------------------------------------------------------------------
# EXTERNAL SERVICES (Phase 2+)
# -----------------------------------------------------------------------------
# InVideo API (for video generation)
INVIDEO_API_KEY=

# ElevenLabs API (for text-to-speech)
ELEVENLABS_API_KEY=

# Stock Media APIs
PEXELS_API_KEY=
UNSPLASH_API_KEY=
PIXABAY_API_KEY=

# -----------------------------------------------------------------------------
# TRANSLATION (DeepL)
# -----------------------------------------------------------------------------
# DeepL API key for EU multilingual article translation (optional, free tier available)
# Get from: https://www.deepl.com/pro-api
DEEPL_API_KEY=
# Use free endpoint by default; switch to https://api.deepl.com/v2/translate for Pro
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# -----------------------------------------------------------------------------
# DEVELOPMENT TOOLS
# -----------------------------------------------------------------------------
# Enable SQL query logging
SQL_ECHO=False

# Enable detailed error messages
SHOW_ERROR_DETAILS=True

# Mock external APIs for testing
MOCK_EXTERNAL_APIS=False

# -----------------------------------------------------------------------------
# OAUTH2 CONFIGURATION
# -----------------------------------------------------------------------------
# Google OAuth2 (for Gmail login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth2 (for Outlook login)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# OAuth CSRF state secret (optional — auto-generated per process if unset,
# but pin in production so OAuth survives restarts mid-flow)
OAUTH_STATE_SECRET=

# -----------------------------------------------------------------------------
# OPERATIONS — Cloud Scheduler & admin endpoints
# -----------------------------------------------------------------------------
# Shared secret Cloud Scheduler must send on the X-Scheduler-Secret header
# when calling /api/scheduler/* and /api/methodology/calibration/refit
SCHEDULER_SECRET=

# Shared secret for admin write endpoints (POST /api/methodology/calibration/labels,
# POST /api/methodology/calibration/refit) — sent on X-Admin-Secret header
CLILENS_CALIBRATION_ADMIN_SECRET=

# -----------------------------------------------------------------------------
# LLM CONFIGURATION
# -----------------------------------------------------------------------------
# Anthropic model identifier used for multi-LLM cross-verification
# (override to claude-sonnet-4-6 or claude-opus-4-7 etc. as the model
# family evolves)
ANTHROPIC_MODEL=claude-sonnet-4-5

# -----------------------------------------------------------------------------
# INGESTION COVERAGE
# -----------------------------------------------------------------------------
# Countries the daily ingestion scheduler discovers articles for. ISO 3166-1
# alpha-2 codes, comma-separated. The default below is a 23-country EU+US/GB
# starter set; deployments serving a global audience MUST override this to
# include Asia, Africa, Latin America, and Oceania for true global coverage.
#
# Suggested global default (~80 countries):
# INGESTION_COUNTRIES=US,GB,CA,AU,NZ,FI,SE,DE,FR,NL,ES,IT,NO,DK,PL,AT,GR,PT,SI,HU,BG,CZ,IE,HR,RO,SK,BE,CH,LU,EE,LV,LT,MT,CY,IS,IN,CN,JP,KR,ID,VN,TH,PH,MY,SG,PK,BD,LK,SA,AE,IL,TR,EG,MA,KE,ZA,NG,GH,ET,DZ,TN,BR,MX,AR,CL,CO,PE,VE,EC,UY,PY,BO,CR,PA,GT,DO,JM,RU,UA,KZ,UZ
#
# Default (23 EU+ countries) — used if unset
INGESTION_COUNTRIES=FI,SE,DE,FR,NL,ES,IT,NO,DK,PL,US,GB,AT,GR,PT,SI,HU,BG,CZ,IE,HR,RO,SK

# -----------------------------------------------------------------------------
# CARF INTEGRATION (Project CARF - Cynefin Reasoning Fabric)
# -----------------------------------------------------------------------------
CARF_API_URL=http://localhost:8000
CARF_API_KEY=
CARF_TIMEOUT=30
