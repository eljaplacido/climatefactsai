{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://climatenews.com/schemas/factcheck_to_creation.json",
  "title": "Fact-Checking to Content Creation Handoff Schema",
  "description": "Standardoitu viesti Fact-Checking -agentilta Content Creation -agentille",
  "version": "1.0",
  "type": "object",
  "required": [
    "schemaVersion",
    "taskId",
    "articleId",
    "verifiedArticle",
    "verifiedClaims"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "taskId": {
      "type": "string",
      "pattern": "^task-[0-9]{8}-[0-9]{3}$"
    },
    "articleId": {
      "type": "string"
    },
    "verifiedArticle": {
      "type": "object",
      "required": ["url", "title", "publishedDate", "extractedText", "overallCredibility"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string"
        },
        "publishedDate": {
          "type": "string",
          "format": "date-time"
        },
        "author": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "sourceCredibilityScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "extractedText": {
          "type": "string"
        },
        "overallCredibility": {
          "type": "string",
          "enum": ["HIGH", "MEDIUM", "LOW", "MIXED"],
          "description": "Artikkelin kokonaisluotettavuus"
        },
        "verifiedClaimsCount": {
          "type": "number",
          "description": "Todennettujen väitteiden määrä"
        },
        "unverifiedClaimsCount": {
          "type": "number",
          "description": "Todentamattomien väitteiden määrä"
        }
      }
    },
    "verifiedClaims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claimId", "claimText", "verificationStatus", "confidence"],
        "properties": {
          "claimId": {
            "type": "string"
          },
          "claimText": {
            "type": "string"
          },
          "context": {
            "type": "string"
          },
          "verificationStatus": {
            "type": "string",
            "enum": ["VERIFIED", "UNVERIFIED", "MISLEADING", "LACKS_CONTEXT", "FALSE"],
            "description": "Todennuksen tulos"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Luottamustaso todennukseen (0-1)"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sourceName", "sourceUrl", "dataPoint"],
              "properties": {
                "sourceName": {
                  "type": "string",
                  "description": "Todistusaineiston lähde (esim. 'ClimateCheck', 'NOAA')"
                },
                "sourceUrl": {
                  "type": "string",
                  "format": "uri",
                  "description": "Linkki lähdetietoon"
                },
                "dataPoint": {
                  "type": "string",
                  "description": "Spesifinen data tai mittaus"
                },
                "retrievalTimestamp": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          },
          "justification": {
            "type": "string",
            "minLength": 20,
            "maxLength": 1000,
            "description": "Lyhyt selitys todennuksen tuloksesta"
          },
          "verifiedDate": {
            "type": "string",
            "format": "date-time"
          },
          "climateCheckScore": {
            "type": "object",
            "properties": {
              "hazardType": {
                "type": "string",
                "enum": [
                  "flood",
                  "heat",
                  "drought",
                  "wildfire",
                  "storm",
                  "sea_level_rise"
                ]
              },
              "riskScore": {
                "type": "number",
                "minimum": 1,
                "maximum": 100,
                "description": "ClimateCheck riskiluku (1-100)"
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "factCheckTimestamp": {
          "type": "string",
          "format": "date-time"
        },
        "processingTimeMs": {
          "type": "number"
        },
        "factCheckAgentVersion": {
          "type": "string"
        },
        "apiCallsMade": {
          "type": "object",
          "properties": {
            "climateCheck": {
              "type": "number"
            },
            "noaa": {
              "type": "number"
            },
            "nasa": {
              "type": "number"
            }
          }
        }
      }
    }
  }
}

