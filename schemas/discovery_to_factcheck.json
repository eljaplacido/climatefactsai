{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://climatenews.com/schemas/discovery_to_factcheck.json",
  "title": "Content Discovery to Fact-Checking Handoff Schema",
  "description": "Standardoitu viesti Content Discovery -agentilta Fact-Checking -agentille",
  "version": "1.0",
  "type": "object",
  "required": [
    "schemaVersion",
    "taskId",
    "articleId",
    "sourceArticle",
    "claims"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Skeeman versio"
    },
    "taskId": {
      "type": "string",
      "pattern": "^task-[0-9]{8}-[0-9]{3}$",
      "description": "Yksilöllinen tehtävän tunniste, esim. task-20251027-001"
    },
    "articleId": {
      "type": "string",
      "description": "Yksilöllinen artikkelin tunniste"
    },
    "sourceArticle": {
      "type": "object",
      "required": ["url", "title", "publishedDate", "extractedText"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Lähdeartikkelin URL"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Artikkelin otsikko"
        },
        "publishedDate": {
          "type": "string",
          "format": "date-time",
          "description": "Julkaisupäivämäärä ISO 8601 -muodossa"
        },
        "author": {
          "type": "string",
          "description": "Artikkelin kirjoittaja (valinnainen)"
        },
        "source": {
          "type": "string",
          "description": "Julkaisun nimi"
        },
        "sourceCredibilityScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Lähteen uskottavuuspisteet (0-100)"
        },
        "extractedText": {
          "type": "string",
          "minLength": 100,
          "description": "Artikkelin täysi teksti"
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}$",
          "default": "fi",
          "description": "Artikkelin kieli (ISO 639-1)"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Metatagit ja kategoriat"
        }
      }
    },
    "claims": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["claimId", "claimText", "context"],
        "properties": {
          "claimId": {
            "type": "string",
            "description": "Yksilöllinen väitteen tunniste"
          },
          "claimText": {
            "type": "string",
            "minLength": 10,
            "maxLength": 1000,
            "description": "Todennettava väite"
          },
          "context": {
            "type": "string",
            "description": "Väitteen konteksti artikkelissa"
          },
          "claimType": {
            "type": "string",
            "enum": [
              "factual_data",
              "prediction",
              "policy_statement",
              "scientific_claim",
              "statistical_claim",
              "event_report"
            ],
            "description": "Väitteen tyyppi"
          },
          "location": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Paikan nimi"
              },
              "latitude": {
                "type": "number",
                "minimum": -90,
                "maximum": 90
              },
              "longitude": {
                "type": "number",
                "minimum": -180,
                "maximum": 180
              },
              "country": {
                "type": "string",
                "pattern": "^[A-Z]{2}$",
                "description": "Maakoodi (ISO 3166-1 alpha-2)"
              }
            }
          },
          "entities": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": ["PERSON", "ORG", "GPE", "DATE", "QUANTITY"]
                }
              }
            },
            "description": "NER-tunnistetut entiteetit väitteessä"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "discoveryTimestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Ajankohta, jolloin artikkeli löydettiin"
        },
        "processingTimeMs": {
          "type": "number",
          "description": "Käsittelyaika millisekunneissa"
        },
        "discoveryAgentVersion": {
          "type": "string",
          "description": "Content Discovery -agentin versio"
        }
      }
    }
  }
}

